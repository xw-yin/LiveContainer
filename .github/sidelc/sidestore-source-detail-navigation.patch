+// MARK: - Language Selection
+
+private extension SettingsViewController
+{
+    func showLanguageSelection()
+    {
+        let currentLanguage = UserDefaults.standard.string(forKey: "ALTSelectedLanguage")
+        
+        let alert = UIAlertController(
+            title: NSLocalizedString("Language", comment: ""),
+            message: NSLocalizedString("Choose your preferred language:", comment: ""),
+            preferredStyle: .actionSheet
+        )
+        
+        let languages: [(title: String, code: String?)] = [
+            (NSLocalizedString("System Default", comment: ""), nil),
+            ("English", "en"),
+            ("中文 (简体)", "zh-Hans")
+        ]
+        
+        for lang in languages {
+            let action = UIAlertAction(title: lang.title, style: .default) { [weak self] _ in
+                self?.changeLanguage(to: lang.code)
+            }
+            if lang.code == currentLanguage || (lang.code == nil && currentLanguage == nil) {
+                action.setValue(true, forKey: "checked")
+            }
+            alert.addAction(action)
+        }
+        
+        alert.addAction(UIAlertAction(title: NSLocalizedString("Cancel", comment: ""), style: .cancel))
+        
+        if let popover = alert.popoverPresentationController,
+           let cell = tableView.cellForRow(at: tableView.indexPathForSelectedRow ?? IndexPath(row: 0, section: 0)) {
+            popover.sourceView = cell
+            popover.sourceRect = cell.bounds
+        }
+        
+        self.present(alert, animated: true)
+    }
+    
+    func changeLanguage(to languageCode: String?)
+    {
+        if let code = languageCode {
+            UserDefaults.standard.set(code, forKey: "ALTSelectedLanguage")
+        } else {
+            UserDefaults.standard.removeObject(forKey: "ALTSelectedLanguage")
+        }
+        
+        Bundle.setLanguage(languageCode)
+        
+        // Hot-reload the root view controller
+        guard let windowScene = UIApplication.shared.connectedScenes.first as? UIWindowScene,
+              let window = windowScene.windows.first else { return }
+        
+        let storyboard = UIStoryboard(name: "Main", bundle: nil)
+        let rootVC = storyboard.instantiateInitialViewController()
+        
+        UIView.transition(with: window, duration: 0.4, options: .transitionCrossDissolve, animations: {
+            window.rootViewController = rootVC
+        }, completion: nil)
+    }
+}
